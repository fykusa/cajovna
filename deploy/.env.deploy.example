# Zkopíruj na deploy/.env.deploy a vyplň (ten soubor NESMÍ do gitu — je v .gitignore).

FTP_HOST=ftp.taocajovna.cz
FTP_USER=
FTP_PASS=

# Cesta na FTP serveru k adresáři /testovaci/ (bez koncového lomítka).
# Zjistíš ve svém FTP klientovi (FileZilla apod.) — obvykle něco jako
# /testovaci nebo /www/testovaci podle toho, kam FTP účet koření.
FTP_REMOTE_PATH=/testovaci
